{
  "$schema": "https://biomejs.dev/schemas/2.4.10/schema.json",
  "extends": ["../../biome.json"],
  "files": {
    "includes": ["**", "!node_modules", "!.next", "!dist", "!build", "!.source"]
  },
  "css": {
